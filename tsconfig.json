{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "jree": ["./node_modules/jree/lib/index.d.ts"]
        },
        "target": "ESNext",
        "module": "Node16",
        "moduleResolution": "Node16",
        "sourceMap": true,
        "esModuleInterop": true,
        "noEmit": false,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "dist",
        "lib": [
            "ESNext",
        ],
        "noImplicitAny": true,
        "strictNullChecks": true,
        "preserveConstEnums": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noFallthroughCasesInSwitch": false,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
    },
    "include": [
        "src/index.ts",
        "src/**/*.ts",
        "parser/generated/**/*.ts",
        "data/**/*.json",
        "tools/*.ts",
        "cli/java2ts.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "tests"
    ],
    "compileOnSave": true,
    "ts-node": {
        "esm": true
    },
    "hooks": [
        "file-permissions"
    ],
    "filePermissions": {
        "output/src/convert.js": "0744"
    }
}
